{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/swift_lifecycle_guard.py\" --reset-best-practices-marker",
            "timeout": 30,
            "statusMessage": "Resetting Swift best-practices read marker"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|functions.exec_command|exec_command|multi_tool_use.parallel",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/swift_lifecycle_guard.py\" --mark-best-practices-read-from-tool-use",
            "timeout": 30,
            "statusMessage": "Recording Swift best-practices read marker"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/swift_lifecycle_guard.py\"",
            "timeout": 30,
            "statusMessage": "Checking Swift lifecycle risk patterns"
          }
        ]
      }
    ]
  }
}
