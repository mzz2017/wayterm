---
import { Icon } from "astro-icon/components";
import { SITE, translations } from "../lib/site";

const whyItems = [
  { key: "native", icon: "lucide:laptop-minimal-check", color: "text-orange-500", bg: "bg-orange-500/10" },
  { key: "modern", icon: "lucide:waypoints", color: "text-amber-500", bg: "bg-amber-500/10" },
  { key: "sync", icon: "lucide:cloudy", color: "text-orange-400", bg: "bg-orange-400/10" },
  { key: "pricing", icon: "lucide:badge-dollar-sign", color: "text-emerald-600", bg: "bg-emerald-500/10" }
];

const featureItems = [
  { key: "rendering", icon: "lucide:square-terminal", color: "text-emerald-600", bg: "bg-emerald-500/10" },
  { key: "connect", icon: "lucide:plug-zap", color: "text-amber-500", bg: "bg-amber-500/10" },
  { key: "files", icon: "lucide:folder-open-dot", color: "text-orange-500", bg: "bg-orange-500/10" },
  { key: "preview", icon: "lucide:file-search-2", color: "text-violet-600", bg: "bg-violet-500/10" },
  { key: "pickup", icon: "lucide:smartphone", color: "text-orange-500", bg: "bg-orange-500/10" },
  { key: "organize", icon: "lucide:folders", color: "text-violet-600", bg: "bg-violet-500/10" }
];

const useCases = [
  { key: "solo", icon: "lucide:user-round" },
  { key: "homelab", icon: "lucide:server-cog" },
  { key: "apple", icon: "lucide:laptop" },
  { key: "ai", icon: "lucide:bot" }
];

const faqs = ["q1", "q2", "q3", "q4", "q5", "q6", "q7", "q8", "q9", "q10"];
const currentYear = new Date().getFullYear();

const highlightAnswer = (text: string) =>
  text
    .replace(/Waterm/g, '<span class="text-orange-500">Waterm</span>')
    .replace(/libghostty/g, '<span class="text-orange-500">libghostty</span>')
    .replace(/Ghostty/g, '<span class="text-orange-500">Ghostty</span>')
    .replace(/iCloud/g, '<span class="text-orange-500">iCloud</span>')
    .replace(/Apple Keychain/g, '<span class="text-orange-500">Apple Keychain</span>')
    .replace(/Keychain/g, '<span class="text-orange-500">Keychain</span>');
---

<main>
  <section class="relative px-4 pb-10 pt-16 sm:px-6 sm:pt-24">
    <div class="relative mx-auto flex max-w-5xl flex-col items-center text-center">
      <div class="max-w-4xl">
        <img src="/logo.png" alt="Waterm" width="96" height="96" class="mx-auto size-24 object-contain drop-shadow-[0_0_28px_rgba(249,115,22,0.18)]" />
        <p class="mt-8 inline-flex min-h-6 items-center justify-center gap-0.5 font-mono text-xs font-semibold uppercase tracking-[0.16em] text-orange-500 sm:text-sm">
          <span data-typing-text>{translations.en.hero.eyebrow}</span>
          <span class="inline-block h-[1.1em] w-[0.7ch] bg-orange-500 align-middle animate-pulse"></span>
        </p>
        <h1 class="mx-auto mt-5 max-w-[17ch] text-5xl font-semibold tracking-[-0.05em] text-slate-950 dark:text-slate-100 sm:text-6xl lg:max-w-[16ch] lg:text-[4.75rem] lg:leading-[0.98]" data-i18n="hero.title">{translations.en.hero.title}</h1>
        <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300 sm:text-xl" data-i18n="hero.subtitle">{translations.en.hero.subtitle}</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a
            class="inline-flex min-h-13 items-center justify-center gap-2 rounded-full bg-orange-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600"
            href={SITE.appStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-track="appstore_click"
            data-conversion-value="0"
          >
            <Icon class="size-4" name="lucide:download" />
            <span data-i18n="hero.primaryCta">{translations.en.hero.primaryCta}</span>
          </a>
          <a
            class="inline-flex min-h-13 items-center justify-center gap-2 rounded-full border border-slate-900/10 bg-white/80 px-6 py-3 text-sm font-semibold text-slate-900 transition hover:-translate-y-0.5 dark:border-white/10 dark:bg-white/5 dark:text-slate-100"
            href={SITE.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-track="github_click_hero"
          >
            <Icon class="size-4" name="lucide:github" />
            <span data-i18n="hero.secondaryCta">{translations.en.hero.secondaryCta}</span>
          </a>
        </div>
        <p class="mt-4 text-sm text-slate-500 dark:text-slate-400" data-i18n-html="hero.meta" set:html={translations.en.hero.meta}></p>
      </div>

      <div class="flex min-h-[300px] w-full items-center justify-center sm:min-h-[420px] lg:min-h-[520px]">
        <img src="/preview.png" alt="Waterm on iPhone, iPad, and Mac" width="1600" height="1100" class="w-full max-w-4xl scale-110 drop-shadow-[0_28px_48px_rgba(15,23,42,0.18)] lg:max-w-[64rem]" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </section>

  <section id="why" class="px-4 py-8 sm:px-6 sm:py-10">
    <div class="mx-auto max-w-6xl">
      <div>
        <h2 class="text-3xl font-semibold tracking-[-0.05em] text-slate-950 dark:text-slate-100 sm:text-5xl" data-i18n="why.title">{translations.en.why.title}</h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600 dark:text-slate-300 sm:text-lg" data-i18n="why.subtitle">{translations.en.why.subtitle}</p>
      </div>
      <div class="mt-8 grid overflow-hidden rounded-[1.5rem] border border-slate-900/8 bg-white/80 dark:border-white/10 dark:bg-white/10 md:grid-cols-2">
        {whyItems.map((item) => (
          <article class="border-b border-slate-900/8 bg-white/85 p-6 dark:border-white/10 dark:bg-[#121214] md:border-r [&:nth-child(2n)]:md:border-r-0 [&:nth-last-child(-n+2)]:border-b-0">
            <div class:list={["mb-4 grid size-11 place-items-center rounded-xl", item.bg, item.color]}>
              <Icon class="size-5" name={item.icon} />
            </div>
            <h3 class="text-xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-slate-100" data-i18n={`why.${item.key}.title`}>
              {translations.en.why[item.key as keyof typeof translations.en.why].title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300" data-i18n={`why.${item.key}.desc`}>
              {translations.en.why[item.key as keyof typeof translations.en.why].desc}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="features" class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div>
        <h2 class="text-3xl font-semibold tracking-[-0.05em] text-slate-950 dark:text-slate-100 sm:text-5xl" data-i18n="features.title">{translations.en.features.title}</h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600 dark:text-slate-300 sm:text-lg" data-i18n="features.subtitle">{translations.en.features.subtitle}</p>
      </div>
      <div class="mt-8 grid gap-px overflow-hidden rounded-[1.5rem] border border-slate-900/8 bg-slate-900/8 dark:border-white/10 dark:bg-white/10 md:grid-cols-2 xl:grid-cols-3">
        {featureItems.map((feature) => (
          <article class="bg-white/90 dark:bg-[#121214] p-7">
            <div class:list={["mb-4 grid size-11 place-items-center rounded-xl", feature.bg, feature.color]}>
              <Icon class="size-5" name={feature.icon} />
            </div>
            <h3 class="text-2xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-slate-100" data-i18n={`features.${feature.key}.title`}>
              {translations.en.features[feature.key as keyof typeof translations.en.features].title}
            </h3>
            <p class="mt-3 text-base leading-8 text-slate-600 dark:text-slate-300" data-i18n={`features.${feature.key}.desc`}>
              {translations.en.features[feature.key as keyof typeof translations.en.features].desc}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="pricing" class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div>
        <h2 class="text-3xl font-semibold tracking-[-0.05em] text-slate-950 dark:text-slate-100 sm:text-5xl" data-i18n="useCases.title">{translations.en.useCases.title}</h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600 dark:text-slate-300 sm:text-lg" data-i18n="useCases.subtitle">{translations.en.useCases.subtitle}</p>
      </div>
      <div class="mt-8 grid gap-px overflow-hidden rounded-[1.5rem] border border-slate-900/8 bg-slate-900/8 dark:border-white/10 dark:bg-white/10 md:grid-cols-2">
        {useCases.map((item) => (
          <article class="bg-white/90 dark:bg-[#121214] p-6">
            <div class="mb-4 flex items-center gap-3">
              <Icon class="size-5 text-orange-500" name={item.icon} />
              <h3 class="text-lg font-semibold tracking-[-0.04em] text-slate-950 dark:text-slate-100 sm:text-xl" data-i18n={`useCases.${item.key}.title`}>
                {translations.en.useCases[item.key as keyof typeof translations.en.useCases].title}
              </h3>
            </div>
            <p class="max-w-[36ch] text-sm leading-7 text-slate-600 dark:text-slate-300" data-i18n={`useCases.${item.key}.desc`}>
              {translations.en.useCases[item.key as keyof typeof translations.en.useCases].desc}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div>
        <h2 class="text-4xl font-semibold tracking-[-0.055em] text-slate-950 dark:text-slate-100 sm:text-6xl" data-i18n="pricing.title">{translations.en.pricing.title}</h2>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300" data-i18n="pricing.subtitle">{translations.en.pricing.subtitle}</p>
      </div>
      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        <article class="flex flex-col rounded-[2rem] border border-slate-900/8 bg-white/95 p-8 shadow-[0_22px_60px_rgba(15,23,42,0.08)] dark:border-white/10 dark:bg-[#121214] dark:shadow-none">
          <h3 class="text-2xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-slate-100" data-i18n="pricing.free.name">{translations.en.pricing.free.name}</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-300" data-i18n="pricing.free.description">{translations.en.pricing.free.description}</p>
          <p class="mt-5">
            <span data-price-text="free">
              <span class="text-5xl font-semibold tracking-[-0.06em] text-slate-950 dark:text-slate-100" data-i18n="pricing.free.price">{translations.en.pricing.free.price}</span>
              <span class="ml-1 text-base text-slate-500 dark:text-slate-400" data-i18n="pricing.free.period">{translations.en.pricing.free.period}</span>
            </span>
          </p>
          <ul class="mb-6 mt-6 grid flex-1 gap-3 text-slate-600 dark:text-slate-300" data-i18n-list="pricing.free.features">
            {translations.en.pricing.free.features.map((item) => (
              <li class="flex gap-3"><span class="text-orange-500">✓</span><span>{item}</span></li>
            ))}
          </ul>
          <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-slate-900/10 bg-white px-5 py-3 text-sm font-semibold text-slate-950 dark:border-white/10 dark:bg-white/5 dark:text-slate-100" href={SITE.appStoreUrl} target="_blank" rel="noopener noreferrer" data-track="pricing_free_click" data-conversion-value="0">
            <span data-i18n="pricing.free.cta">{translations.en.pricing.free.cta}</span>
          </a>
        </article>

        <article class="flex flex-col rounded-[2rem] border border-slate-900/8 bg-white/95 p-8 shadow-[0_22px_60px_rgba(15,23,42,0.08)] dark:border-white/10 dark:bg-[#121214] dark:shadow-none">
          <h3 class="text-2xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-slate-100" data-i18n="pricing.pro.name">{translations.en.pricing.pro.name}</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-300" data-i18n="pricing.pro.description">{translations.en.pricing.pro.description}</p>
          <div class="mt-5 flex gap-1 rounded-full bg-slate-100 p-1 dark:bg-white/8">
            <button type="button" class="flex-1 rounded-full px-4 py-3 text-sm font-medium text-slate-500 dark:text-slate-400" data-billing-toggle="monthly">Monthly</button>
            <button type="button" class="is-active flex-1 rounded-full bg-white px-4 py-3 text-sm font-medium text-slate-950 shadow-sm dark:bg-white/10 dark:text-slate-100 dark:shadow-none" data-billing-toggle="yearly">
              Yearly
              <span class="ml-2 text-xs text-emerald-600" data-i18n="pricing.pro.yearly.save">{translations.en.pricing.pro.yearly.save}</span>
            </button>
          </div>
          <p class="mt-5">
            <span data-price-monthly hidden>
              <span class="text-5xl font-semibold tracking-[-0.06em] text-slate-950 dark:text-slate-100" data-i18n="pricing.pro.monthly.price">{translations.en.pricing.pro.monthly.price}</span>
              <span class="ml-1 text-base text-slate-500 dark:text-slate-400" data-i18n="pricing.pro.monthly.period">{translations.en.pricing.pro.monthly.period}</span>
            </span>
            <span data-price-yearly>
              <span class="text-5xl font-semibold tracking-[-0.06em] text-slate-950 dark:text-slate-100" data-i18n="pricing.pro.yearly.price">{translations.en.pricing.pro.yearly.price}</span>
              <span class="ml-1 text-base text-slate-500 dark:text-slate-400" data-i18n="pricing.pro.yearly.period">{translations.en.pricing.pro.yearly.period}</span>
            </span>
          </p>
          <ul class="mb-6 mt-6 grid flex-1 gap-3 text-slate-600 dark:text-slate-300" data-i18n-list="pricing.pro.features">
            {translations.en.pricing.pro.features.map((item) => (
              <li class="flex gap-3"><span class="text-orange-500">✓</span><span>{item}</span></li>
            ))}
          </ul>
          <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-slate-900/10 bg-white px-5 py-3 text-sm font-semibold text-slate-950 dark:border-white/10 dark:bg-white/5 dark:text-slate-100" href={SITE.appStoreUrl} target="_blank" rel="noopener noreferrer" data-pricing-cta data-monthly-label={translations.en.pricing.pro.ctaMonthly} data-yearly-label={translations.en.pricing.pro.ctaYearly} data-monthly-track="pricing_pro_monthly_click" data-yearly-track="pricing_pro_yearly_click" data-monthly-value="6.49" data-yearly-value="24.99" data-billing-cycle="yearly" data-track="pricing_pro_yearly_click" data-conversion-value="24.99">
            <span data-i18n="pricing.pro.ctaYearly">{translations.en.pricing.pro.ctaYearly}</span>
          </a>
        </article>

        <article class="flex flex-col rounded-[2rem] border border-orange-200/70 bg-white/95 p-8 shadow-[0_22px_60px_rgba(15,23,42,0.08)] dark:border-orange-400/30 dark:bg-orange-500/10 dark:shadow-none">
          <div class="ml-auto rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-500 dark:bg-orange-500/15" data-i18n="pricing.lifetime.badge">{translations.en.pricing.lifetime.badge}</div>
          <h3 class="mt-4 text-2xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-slate-100" data-i18n="pricing.lifetime.name">{translations.en.pricing.lifetime.name}</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-300" data-i18n="pricing.lifetime.description">{translations.en.pricing.lifetime.description}</p>
          <p class="mt-5">
            <span class="text-5xl font-semibold tracking-[-0.06em] text-slate-950 dark:text-slate-100" data-i18n="pricing.lifetime.price">{translations.en.pricing.lifetime.price}</span>
          </p>
          <ul class="mb-6 mt-6 grid flex-1 gap-3 text-slate-600 dark:text-slate-300" data-i18n-list="pricing.lifetime.features">
            {translations.en.pricing.lifetime.features.map((item) => (
              <li class="flex gap-3"><span class="text-orange-500">✓</span><span>{item}</span></li>
            ))}
          </ul>
          <a class="inline-flex min-h-12 items-center justify-center rounded-full bg-orange-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" href={SITE.appStoreUrl} target="_blank" rel="noopener noreferrer" data-track="pricing_lifetime_click" data-conversion-value="49.99">
            <span data-i18n="pricing.lifetime.cta">{translations.en.pricing.lifetime.cta}</span>
          </a>
          <p class="mt-4 text-center text-sm text-slate-500 dark:text-slate-400" data-i18n="pricing.lifetime.guarantee">{translations.en.pricing.lifetime.guarantee}</p>
        </article>
      </div>
    </div>
  </section>

  <section id="faq" class="px-4 py-8 sm:px-6 sm:py-10">
    <div class="mx-auto max-w-6xl">
      <div>
        <h2 class="text-3xl font-semibold tracking-[-0.05em] text-slate-950 dark:text-slate-100 sm:text-5xl" data-i18n="faq.title">{translations.en.faq.title}</h2>
      </div>
      <div class="mt-6 grid gap-4">
        {faqs.map((key) => (
          <article class="border-b border-slate-900/8 pb-4 dark:border-white/10 last:border-b-0 last:pb-0">
            <h3 class="text-lg font-semibold tracking-[-0.03em] text-slate-950 dark:text-slate-100" data-i18n={`faq.${key}.question`}>
              {translations.en.faq[key as keyof typeof translations.en.faq].question}
            </h3>
            <p class="mt-2 text-[15px] leading-7 text-slate-600 dark:text-slate-300" data-i18n-html={`faq.${key}.answer`} set:html={highlightAnswer(translations.en.faq[key as keyof typeof translations.en.faq].answer)} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 sm:py-16">
    <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
      <img src="/logo.png" alt="Waterm" width="72" height="72" class="size-18 object-contain drop-shadow-[0_0_24px_rgba(249,115,22,0.16)]" />
      <h2 class="mt-6 text-3xl font-semibold tracking-[-0.05em] text-slate-950 dark:text-slate-100 sm:text-5xl" data-i18n="closing.title">{translations.en.closing.title}</h2>
      <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600 dark:text-slate-300 sm:text-lg" data-i18n="closing.subtitle">{translations.en.closing.subtitle}</p>
      <a
        class="mt-8 inline-flex min-h-13 items-center justify-center gap-2 rounded-full bg-orange-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600"
        href={SITE.appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-track="closing_appstore_click"
        data-conversion-value="0"
      >
        <Icon class="size-4" name="lucide:download" />
        <span data-i18n="closing.cta">{translations.en.closing.cta}</span>
      </a>
    </div>
  </section>

  <footer class="relative px-4 pb-12 pt-14 text-slate-900 [background-image:radial-gradient(ellipse_70%_38%_at_50%_100%,rgba(249,115,22,0.10)_0%,rgba(249,115,22,0.03)_34%,transparent_72%)] dark:text-slate-100 dark:[background-image:radial-gradient(ellipse_70%_38%_at_50%_100%,rgba(249,115,22,0.18)_0%,rgba(249,115,22,0.05)_34%,transparent_72%)] sm:px-6 sm:pb-16 sm:pt-18">
    <div class="relative mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(0,0.75fr)_minmax(0,0.75fr)]">
      <div class="max-w-xl">
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="Waterm" width="48" height="48" class="size-12 object-contain" />
          <div>
            <p class="text-xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-white">Waterm</p>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400" data-i18n="footer.tagline">{translations.en.footer.tagline}</p>
          </div>
        </div>
        <p class="mt-6 max-w-lg text-sm leading-7 text-slate-600 dark:text-slate-400" data-i18n="footer.description">
          {translations.en.footer.description}
        </p>
        <p class="mt-6 text-sm text-slate-500 dark:text-slate-500">© {currentYear} <span data-i18n="footer.copyright">{translations.en.footer.copyright}</span></p>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-500" data-i18n="footer.productTitle">{translations.en.footer.productTitle}</p>
        <nav class="mt-5 grid gap-3 text-sm text-slate-700 dark:text-slate-300">
          <a href="#why" class="transition hover:text-orange-500" data-i18n="footer.navWhy">{translations.en.footer.navWhy}</a>
          <a href="#features" class="transition hover:text-orange-500" data-i18n="footer.navFeatures">{translations.en.footer.navFeatures}</a>
          <a href="#pricing" class="transition hover:text-orange-500" data-i18n="footer.navPricing">{translations.en.footer.navPricing}</a>
          <a href="#faq" class="transition hover:text-orange-500" data-i18n="footer.navFaq">{translations.en.footer.navFaq}</a>
          <a class="inline-flex items-center gap-2 transition hover:text-orange-500" href={SITE.githubUrl} target="_blank" rel="noopener noreferrer" data-track="github_click_footer">
            <Icon class="size-4" name="lucide:github" />
            <span data-i18n="hero.secondaryCta">{translations.en.hero.secondaryCta}</span>
          </a>
        </nav>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-500" data-i18n="footer.resourcesTitle">{translations.en.footer.resourcesTitle}</p>
        <nav class="mt-5 grid gap-3 text-sm text-slate-700 dark:text-slate-300">
          <a href={SITE.discordUrl} target="_blank" rel="noopener noreferrer" data-track="discord_click" data-i18n="footer.discord" class="transition hover:text-orange-500">
            {translations.en.footer.discord}
          </a>
          <a href="/privacy" class="transition hover:text-orange-500" data-i18n="footer.privacy">{translations.en.footer.privacy}</a>
          <a href="/terms" class="transition hover:text-orange-500" data-i18n="footer.terms">{translations.en.footer.terms}</a>
          <a href="/refund" class="transition hover:text-orange-500" data-i18n="footer.refunds">{translations.en.footer.refunds}</a>
          <a href="/support" class="transition hover:text-orange-500" data-i18n="footer.support">{translations.en.footer.support}</a>
        </nav>
      </div>
    </div>
    <div class="relative mx-auto mt-10 flex max-w-6xl justify-center lg:justify-end">
      <div class="flex items-center gap-2 sm:gap-3">
        <button
          type="button"
          aria-label="Toggle theme"
          data-theme-toggle
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-900/10 bg-white text-slate-700 transition hover:border-slate-900/15 hover:bg-slate-50 dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:bg-white/10"
        >
          <Icon class="size-4 dark:hidden" name="lucide:moon" />
          <Icon class="hidden size-4 dark:block" name="lucide:sun" />
        </button>
        <div class="relative">
          <select
            class="h-10 cursor-pointer appearance-none rounded-full border border-slate-900/10 bg-white pl-4 pr-10 text-sm text-slate-700 transition hover:border-slate-900/15 hover:bg-slate-50 dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:bg-white/10"
            aria-label="Select language"
            data-language-select
          >
            <option value="en">English</option>
            <option value="zh">中文</option>
          </select>
          <Icon class="pointer-events-none absolute right-3 top-1/2 size-4 -translate-y-1/2 text-slate-400 dark:text-slate-500" name="lucide:chevron-down" />
        </div>
      </div>
    </div>
  </footer>
</main>

<script is:inline define:vars={{ translations, gtagConversionId: SITE.gtagConversionId }}>
  const langSelect = document.querySelector("[data-language-select]");
  const themeToggle = document.querySelector("[data-theme-toggle]");
  const typingText = document.querySelector("[data-typing-text]");
  const billingButtons = Array.from(document.querySelectorAll("[data-billing-toggle]"));
  const pricingCta = document.querySelector("[data-pricing-cta]");
  const monthlyPrice = document.querySelector("[data-price-monthly]");
  const yearlyPrice = document.querySelector("[data-price-yearly]");
  let typingTimer = null;
  let typingVersion = 0;

  const getByPath = (object, path) =>
    path.split(".").reduce((value, part) => (value == null ? value : value[part]), object);

  const highlightAnswer = (text) =>
    text
      .replace(/Waterm/g, '<span class="text-orange-500">Waterm</span>')
      .replace(/libghostty/g, '<span class="text-orange-500">libghostty</span>')
      .replace(/Ghostty/g, '<span class="text-orange-500">Ghostty</span>')
      .replace(/iCloud/g, '<span class="text-orange-500">iCloud</span>')
      .replace(/Apple Keychain/g, '<span class="text-orange-500">Apple Keychain</span>')
      .replace(/Keychain/g, '<span class="text-orange-500">Keychain</span>');

  const startTypingSequence = (phrases) => {
    if (!typingText || !Array.isArray(phrases) || !phrases.length) return;
    typingVersion += 1;
    const version = typingVersion;
    if (typingTimer) window.clearTimeout(typingTimer);

    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;

    const tick = () => {
      if (version !== typingVersion) return;
      const currentPhrase = phrases[phraseIndex] || "";

      if (!deleting) {
        charIndex += 1;
        typingText.textContent = currentPhrase.slice(0, charIndex);
        if (charIndex >= currentPhrase.length) {
          typingTimer = window.setTimeout(() => {
            deleting = true;
            tick();
          }, 1400);
          return;
        }
        typingTimer = window.setTimeout(tick, 72);
        return;
      }

      charIndex -= 1;
      typingText.textContent = currentPhrase.slice(0, Math.max(0, charIndex));
      if (charIndex <= 0) {
        deleting = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        typingTimer = window.setTimeout(tick, 220);
        return;
      }
      typingTimer = window.setTimeout(tick, 42);
    };

    typingText.textContent = "";
    tick();
  };

  const applyLanguage = (lang) => {
    const dictionary = translations[lang] || translations.en;
    document.documentElement.lang = lang === "zh" ? "zh-CN" : "en";
    if (langSelect) langSelect.value = lang;

    document.querySelectorAll("[data-i18n]").forEach((node) => {
      const value = getByPath(dictionary, node.dataset.i18n);
      if (typeof value === "string") node.textContent = value;
    });

    document.querySelectorAll("[data-i18n-html]").forEach((node) => {
      const value = getByPath(dictionary, node.dataset.i18nHtml);
      if (typeof value === "string") node.innerHTML = highlightAnswer(value);
    });

    document.querySelectorAll("[data-i18n-list]").forEach((node) => {
      const items = getByPath(dictionary, node.dataset.i18nList);
      if (!Array.isArray(items)) return;
      const isComparison = node.dataset.i18nList === "comparison.items";
      node.innerHTML = items.map((item) => isComparison
        ? `<li class="flex gap-3"><span class="font-semibold text-orange-500">•</span><span>${item}</span></li>`
        : `<li class="flex gap-3"><span class="text-orange-500">✓</span><span>${item}</span></li>`).join("");
    });

    if (pricingCta) {
      pricingCta.dataset.monthlyLabel = dictionary.pricing.pro.ctaMonthly;
      pricingCta.dataset.yearlyLabel = dictionary.pricing.pro.ctaYearly;
      syncBilling(pricingCta.dataset.billingCycle || "yearly");
    }

    startTypingSequence(dictionary.hero.eyebrowSequence || [dictionary.hero.eyebrow]);
  };

  const syncBilling = (cycle) => {
    const isYearly = cycle === "yearly";
    billingButtons.forEach((button) => {
      button.classList.toggle("is-active", button.dataset.billingToggle === cycle);
      button.classList.toggle("bg-white", button.dataset.billingToggle === cycle);
      button.classList.toggle("dark:bg-white/10", button.dataset.billingToggle === cycle);
      button.classList.toggle("text-slate-950", button.dataset.billingToggle === cycle);
      button.classList.toggle("dark:text-slate-100", button.dataset.billingToggle === cycle);
      button.classList.toggle("shadow-sm", button.dataset.billingToggle === cycle);
      button.classList.toggle("text-slate-500", button.dataset.billingToggle !== cycle);
      button.classList.toggle("dark:text-slate-400", button.dataset.billingToggle !== cycle);
    });

    if (monthlyPrice) monthlyPrice.hidden = isYearly;
    if (yearlyPrice) yearlyPrice.hidden = !isYearly;
    if (!pricingCta) return;

    pricingCta.dataset.billingCycle = cycle;
    pricingCta.dataset.track = isYearly ? pricingCta.dataset.yearlyTrack : pricingCta.dataset.monthlyTrack;
    pricingCta.dataset.conversionValue = isYearly ? pricingCta.dataset.yearlyValue : pricingCta.dataset.monthlyValue;
    pricingCta.textContent = isYearly ? pricingCta.dataset.yearlyLabel : pricingCta.dataset.monthlyLabel;
  };

  const trackEvent = (eventName) => {
    if (window.umami && typeof window.umami.track === "function") window.umami.track(eventName);
  };

  const trackConversion = (event, eventName, value) => {
    trackEvent(eventName);
    if (typeof window.gtag !== "function") return;
    event.preventDefault();
    const url = event.currentTarget.href;
    let navigated = false;
    const navigate = () => {
      if (navigated) return;
      navigated = true;
      window.open(url, "_blank", "noopener,noreferrer");
    };
    window.gtag("event", "conversion", {
      send_to: gtagConversionId,
      value: value || 0,
      currency: "USD",
      transaction_id: `${eventName}_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`,
      event_callback: navigate,
    });
    window.setTimeout(navigate, 1000);
  };

  if (langSelect) {
    const storedLanguage = localStorage.getItem("waterm-language");
    const preferredLanguage = storedLanguage || ((navigator.language || "").startsWith("zh") ? "zh" : "en");
    applyLanguage(preferredLanguage);
    langSelect.addEventListener("change", (event) => {
      const lang = event.currentTarget.value;
      localStorage.setItem("waterm-language", lang);
      applyLanguage(lang);
      trackEvent(`language_change_${lang}`);
    });
  }

  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("waterm-theme", isDark ? "dark" : "light");
    });
  }

  billingButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const cycle = button.dataset.billingToggle;
      if (!cycle) return;
      syncBilling(cycle);
      trackEvent(`billing_toggle_${cycle}`);
    });
  });

  document.querySelectorAll("[data-track]").forEach((link) => {
    link.addEventListener("click", (event) => {
      const eventName = link.dataset.track;
      const value = Number(link.dataset.conversionValue || "0");
      if (!eventName) return;
      if (link.dataset.conversionValue != null) {
        trackConversion(event, eventName, value);
      } else {
        trackEvent(eventName);
      }
    });
  });

  if (pricingCta) syncBilling(pricingCta.dataset.billingCycle || "yearly");
</script>
