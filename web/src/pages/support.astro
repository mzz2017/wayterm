---
import LegalPage from "../components/LegalPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Support - Waterm"
  description="Support resources for Waterm, including contact and billing guidance."
  canonicalPath="/support"
  ogType="article"
>
  <LegalPage title="Support" description="We’re here to help with any questions about Waterm.">
    <section>
      <h2>Contact</h2>
      <p>
        Email us at <a href="mailto:waterm@vivy.company">waterm@vivy.company</a>. We typically respond
        within 1 to 2 business days.
      </p>
    </section>

    <section>
      <h2>App Support</h2>
      <p>Please include the following so we can help faster:</p>
      <ul>
        <li>Device model and OS version</li>
        <li>Waterm app version</li>
        <li>Steps to reproduce the issue</li>
        <li>Any relevant screenshots or logs</li>
      </ul>
    </section>

    <section>
      <h2>Billing and Subscriptions</h2>
      <p>
        Purchases are handled by the App Store. If you have billing questions, you can contact us or
        manage subscriptions in your Apple ID settings.
      </p>
    </section>
  </LegalPage>
</BaseLayout>
